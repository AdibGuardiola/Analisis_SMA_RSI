    c4.metric("Estado", signal_txt)

    fig = make_chart(data.tail(250), interval, show_labels=show_labels)
    st.plotly_chart(fig, use_container_width=True)

    with st.expander("Últimas señales"):
        signals = data.loc[data["BUY_SIGNAL"] | data["SELL_SIGNAL"]].copy()
        signals["Signal"] = np.where(
            signals["BUY_SIGNAL_HP"], "BUY ⭐", 
            np.where(signals["SELL_SIGNAL_HP"], "SELL ⭐", 
